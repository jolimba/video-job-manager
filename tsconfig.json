{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",  
    "moduleResolution": "NodeNext", 
    "outDir": "./dist", 
    "rootDir": "./src", 
    "experimentalDecorators": true, 
    "emitDecoratorMetadata": true, 
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true,
    "strict": true, 
    "skipLibCheck": true,
    "types": ["node", "jest"]                                 
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}